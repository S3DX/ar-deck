#!/usr/bin/env bash
set -u

APP_NAME="Deck Virtual Paste"
DELAY_SECONDS=5
TYPE_DELAY_MS=20

notify() {
  local msg="$1"
  if command -v kdialog >/dev/null 2>&1; then
    kdialog --title "$APP_NAME" --passivepopup "$msg" 4 >/dev/null 2>&1 || true
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send "$APP_NAME" "$msg" >/dev/null 2>&1 || true
  else
    printf '%s\n' "$msg" >&2
  fi
}

error_box() {
  local msg="$1"
  if command -v kdialog >/dev/null 2>&1; then
    kdialog --title "$APP_NAME" --error "$msg" >/dev/null 2>&1 || true
  else
    printf 'ERROR: %s\n' "$msg" >&2
  fi
}

read_clipboard() {
  if command -v qdbus6 >/dev/null 2>&1; then
    qdbus6 org.kde.klipper /klipper org.kde.klipper.klipper.getClipboardContents 2>/dev/null && return 0
    qdbus6 org.kde.klipper /klipper getClipboardContents 2>/dev/null && return 0
  fi

  if command -v qdbus >/dev/null 2>&1; then
    qdbus org.kde.klipper /klipper org.kde.klipper.klipper.getClipboardContents 2>/dev/null && return 0
    qdbus org.kde.klipper /klipper getClipboardContents 2>/dev/null && return 0
  fi

  if command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard -o 2>/dev/null && return 0
  fi

  if command -v xsel >/dev/null 2>&1; then
    xsel -b -o 2>/dev/null && return 0
  fi

  if command -v wl-paste >/dev/null 2>&1; then
    wl-paste -n 2>/dev/null && return 0
  fi

  return 1
}

strip_trailing_newlines() {
  local text="$1"
  while [[ "$text" == *$'\n' || "$text" == *$'\r' ]]; do
    text="${text%$'\n'}"
    text="${text%$'\r'}"
  done
  printf '%s' "$text"
}

fake_type() {
  local text="$1"
  local session_type="${XDG_SESSION_TYPE:-unknown}"

  if [[ "$session_type" == "wayland" ]] && command -v wtype >/dev/null 2>&1; then
    if wtype -s "$TYPE_DELAY_MS" "$text" >/dev/null 2>&1; then
      return 0
    fi
    wtype "$text"
    return $?
  fi

  if command -v xdotool >/dev/null 2>&1; then
    xdotool type --clearmodifiers --delay "$TYPE_DELAY_MS" -- "$text"
    return $?
  fi

  if command -v wtype >/dev/null 2>&1; then
    if wtype -s "$TYPE_DELAY_MS" "$text" >/dev/null 2>&1; then
      return 0
    fi
    wtype "$text"
    return $?
  fi

  return 127
}

confirm_ui() {
  if command -v kdialog >/dev/null 2>&1; then
    kdialog \
      --title "$APP_NAME" \
      --yesno "Copy your password/text first.\n\nPress the big button, then tap the Steam password field within $DELAY_SECONDS seconds.\n\nThe clipboard will be typed as fake keyboard input. It will not be displayed." \
      --yes-label "TYPE CLIPBOARD IN $DELAY_SECONDS SECONDS" \
      --no-label "CANCEL" >/dev/null 2>&1
    return $?
  fi

  printf '%s\n' "$APP_NAME"
  printf '%s\n' "Press ENTER, then click/tap the target field within $DELAY_SECONDS seconds. Ctrl+C to cancel."
  read -r _
  return 0
}

main() {
  if ! confirm_ui; then
    exit 0
  fi

  local text
  text="$(read_clipboard || true)"
  text="$(strip_trailing_newlines "$text")"

  if [[ -z "$text" ]]; then
    error_box "Clipboard is empty or could not be read. Copy the password/text first, then launch $APP_NAME again."
    exit 1
  fi

  if ! command -v xdotool >/dev/null 2>&1 && ! command -v wtype >/dev/null 2>&1; then
    error_box "No fake-typing backend found. Install xdotool for X11 or wtype for Wayland, then try again."
    exit 2
  fi

  notify "Tap the Steam password field now. Typing starts in $DELAY_SECONDS seconds."
  sleep "$DELAY_SECONDS"

  if ! fake_type "$text"; then
    error_box "Fake typing failed. Make sure the Steam password field was focused before the countdown ended."
    exit 3
  fi
}

main "$@"
